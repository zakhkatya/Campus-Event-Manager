{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Docker: Attach Debugger", // Bu isim, aradığınız isimdir
            "type": "python",
            "request": "attach",
            "port": 5678, 
            "host": "localhost",
            "pathMappings": [
                {
                    // VS Code'daki yerel Django kodlarının yolu
                    "localRoot": "${workspaceFolder}/ems", 
                    // Kapsayıcıdaki çalışma dizini
                    "remoteRoot": "/home/app/web"
                }
            ],
        }
    ]
}